{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".", // Titik awal pencarian path
    "paths": {
      "@shared/*": ["shared/*"],
      "@backend/*": ["backend/src/*"]
    },
    "composite": true, // Penting untuk monorepo
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
