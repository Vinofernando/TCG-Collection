{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    // Tarik rootDir satu tingkat ke atas agar mencakup folder 'shared'
